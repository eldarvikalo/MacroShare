{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=macroshare;Username=postgres;Password=postgres"
  },
  "Seeding": {
    "IngredientsFilePath": "../../data/ingredients.json"
  },
  "OpenFoodFacts": {
    "FilePath": "../../en.openfoodfacts.org.products.csv",
    "MaxItems": 50000
  },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:5173", "http://localhost:3000" ]
  },
  "Jwt": {
    "Key": "MacroShare-Dev-Secret-Key-Min-32-Chars-Long!",
    "Issuer": "MacroShare",
    "Audience": "MacroShareClient",
    "ExpiryDays": 30
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "AllowedHosts": "*"
}
